# API endpoint the admin SPA should talk to (Django REST API base, including /api).
# Leave empty to be prompted for the endpoint inside the app on first load.
#   - same-domain deploy: API_BASE=/api
#   - separate domain:    API_BASE=https://api.example.com/api
#   - local dev:          API_BASE=http://localhost:8000/api
API_BASE=

# Comma-separated list of allowed hosts for dev server
# Example: localhost,127.0.0.1,example.com,universal-officer-fellow-limiting.trycloudflare.com
ALLOWED_HOSTS=
